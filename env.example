# Configuration locale du projet (non versionne, voir .gitignore).
# Charge automatiquement par src/bank_marketing/config.py.

# URI du serveur de tracking MLflow
MLFLOW_TRACKING_URI=http://127.0.0.1:5000

# Nom de l'experience MLflow utilisee par les scripts d'entrainement
MLFLOW_EXPERIMENT=bank-marketing-baseline

# Description de l'experience (affichee dans l'UI MLflow)
MLFLOW_EXPERIMENT_DESCRIPTION=Bank Marketing - prediction de souscription a un depot a terme (cours MLOps)

# Tags de l'experience, format cle=valeur separes par des virgules
MLFLOW_EXPERIMENT_TAGS=course=mlops,dataset=bank-marketing

# Nom du modele dans le MLflow Model Registry
MODEL_NAME=bank-marketing-classifier

# Seuils de la porte qualite (a venir) : modele rejete si en dessous
EVAL_ROC_AUC_MIN=0.65
EVAL_F1_MIN=0.55

# URL de l'API FastAPI (a venir)
API_URL=http://127.0.0.1:8000
