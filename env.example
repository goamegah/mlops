# Configuration du projet MLOps (copie dans .env, non versionne voir .gitignore).
# Charge automatiquement par src/bank_marketing/config.py et frontend/app.py.
#
# INSTRUCTIONS : Choisir la section correspondant à votre environnement et décommenter.
# ==============================================================================

# ==============================================================================
# POUR DÉVELOPPEMENT LOCAL (Docker compose up -d)
# ==============================================================================
MLFLOW_TRACKING_URI=http://mlflow:5000
MLFLOW_EXPERIMENT=bank-marketing-baseline
MLFLOW_EXPERIMENT_DESCRIPTION=Bank Marketing - prediction de souscription a un depot a terme (cours MLOps)
MLFLOW_EXPERIMENT_TAGS=course=mlops,dataset=bank-marketing
MODEL_NAME=bank-marketing-classifier
# Seuils de la porte qualite (frontend + DAG Airflow). f1 a 0.30 car le dataset
# est desequilibre (~12% de positifs) : au seuil 0.5 le modele fait ~0.34. Un
# 0.55 generique rejetterait tout bon modele. Voir bank_marketing/config.py.
EVAL_ROC_AUC_MIN=0.65
EVAL_F1_MIN=0.30
API_URL=http://127.0.0.1:8000
DATABASE_URL=mysql+pymysql://bank:bank@127.0.0.1:3306/bankmarketing
MLFLOW_UI_URL=http://localhost:5000
API_PUBLIC_URL=http://localhost:8000
AIRFLOW_UI_URL=http://localhost:8080

# ==============================================================================
# POUR VM (Ubuntu SSH, hors Docker - DÉCOMMENTER POUR VM)
# ==============================================================================
# MLFLOW_TRACKING_URI=http://127.0.0.1:5000
# MLFLOW_EXPERIMENT=bank-marketing-baseline
# MLFLOW_EXPERIMENT_DESCRIPTION=Bank Marketing - prediction de souscription a un depot a terme (cours MLOps)
# MLFLOW_EXPERIMENT_TAGS=course=mlops,dataset=bank-marketing
# MODEL_NAME=bank-marketing-classifier
# EVAL_ROC_AUC_MIN=0.65
# EVAL_F1_MIN=0.30
# API_URL=http://127.0.0.1:8000
# DATABASE_URL=mysql+pymysql://bank:bank@127.0.0.1:3306/bankmarketing
# MLFLOW_UI_URL=http://88.96.57.10:5000
# API_PUBLIC_URL=http://88.96.57.10:8000
# AIRFLOW_UI_URL=http://88.96.57.10:8080

# ==============================================================================
# Frontend : Branding (optionnel, commun à tous les environnements)
# ==============================================================================
GITHUB_URL=https://github.com/goamegah/mlops
AUTHOR=Godwin Amegah
AUTHOR_SUBTITLE=Cloud ML engineer
