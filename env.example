# Configuration locale du projet (non versionne, voir .gitignore).
# Charge automatiquement par src/bank_marketing/config.py et frontend/app.py.

# ==============================================================================
# Backend : MLflow + Model Registry
# ==============================================================================
MLFLOW_TRACKING_URI=http://127.0.0.1:5000
MLFLOW_EXPERIMENT=bank-marketing-baseline
MLFLOW_EXPERIMENT_DESCRIPTION=Bank Marketing - prediction de souscription a un depot a terme (cours MLOps)
MLFLOW_EXPERIMENT_TAGS=course=mlops,dataset=bank-marketing
MODEL_NAME=bank-marketing-classifier

# ==============================================================================
# Backend : Porte qualite
# ==============================================================================
EVAL_ROC_AUC_MIN=0.65
EVAL_F1_MIN=0.55

# ==============================================================================
# Backend : API + Base de donnees
# ==============================================================================
API_URL=http://127.0.0.1:8000
DATABASE_URL=mysql+pymysql://bank:bank@127.0.0.1:3306/bankmarketing

# ==============================================================================
# Frontend : URLs publiques pour les liens sidebar
# ==============================================================================
# URLs accessibles depuis le navigateur (pour les boutons/liens du dashboard).
# En local : http://localhost:XXXX
# En production VM : http://IP_PUBLIQUE:PORT ou http://domain.com:PORT
# Laisser vide pour masquer les liens correspondants.

# URL publique pour acceder a MLflow Registry (ex: http://88.96.57.10:5000)
MLFLOW_UI_URL=http://127.0.0.1:5000

# URL publique pour acceder a l'API Swagger (ex: http://88.96.57.10:8000)
API_PUBLIC_URL=http://127.0.0.1:8000

# URL publique pour acceder a Airflow UI (ex: http://88.96.57.10:8080)
AIRFLOW_UI_URL=http://127.0.0.1:8080

# URL du repository GitHub (pour le lien "Voir le code")
GITHUB_URL=https://github.com/goamegah/mlops

# ==============================================================================
# Frontend : Branding (optionnel)
# ==============================================================================
AUTHOR=Godwin Amegah
AUTHOR_SUBTITLE=Cloud ML engineer
